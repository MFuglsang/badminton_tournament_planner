# ── Forms – validation errors ───────────────────────────────────────────

msgid "Select pair type (doubles or mixed doubles) when adding two players."
msgstr "Vælg partype (double eller mixeddouble) når du tilføjer to spillere."

msgid "Doubles requires two players of the same gender."
msgstr "Double kræver to spillere af samme køn."

msgid "Mixed doubles requires one male and one female player."
msgstr "Mixeddouble kræver én mandlig og én kvindelig spiller."

msgid "— Select division —"
msgstr "— Vælg række —"

msgid "A badminton match is best of 3 sets – provide 2 or 3 sets."
msgstr "En badmintonkamp er bedst af 3 sæt – angiv 2 eller 3 sæt."

msgid "No set score found"
msgstr "Ingen sætscore fundet"

msgid "Invalid format: '%(part)s'. Write each set as e.g. 21-15"
msgstr "Ugyldigt format: '%(part)s'. Skriv hvert sæt f.eks. 21-15"

msgid "Invalid set: %(err)s"
msgstr "Ugyldigt sæt: %(err)s"

msgid "%(a)s-%(b)s: a set cannot end in a draw"
msgstr "%(a)s-%(b)s: et sæt kan ikke slutte uafgjort"

msgid "%(a)s-%(b)s: at 20-20 play continues to 2 points difference (e.g. 22-20)"
msgstr "%(a)s-%(b)s: ved 20-20 fortsættes til 2 points forskel (f.eks. 22-20)"

msgid "%(a)s-%(b)s: invalid set result (in extended play the difference must be exactly 2 points)"
msgstr "%(a)s-%(b)s: ugyldigt sætresultat (i forlænget spil skal forskellen være præcis 2 points)"

msgid "%(a)s-%(b)s: maximum score is 30-29"
msgstr "%(a)s-%(b)s: maksimalt resultat er 30-29"

msgid "%(a)s-%(b)s: the winner must have at least 21 points"
msgstr "%(a)s-%(b)s: vinderen skal have mindst 21 points"

msgid "The winner must have exactly 2 set wins (current count: %(t1)s–%(t2)s)."
msgstr "Vinderen skal have præcis 2 sætsejre (nuværende antal: %(t1)s–%(t2)s)."

msgid "Third set is unnecessary: one player already won the first two sets."
msgstr "Tredje sæt er unødvendigt: en spiller har allerede vundet de to første sæt."

msgid "Winner does not match the score: according to the result %(winner)s won (%(t1)s–%(t2)s sets), but you selected %(selected)s as winner."
msgstr "Vinderen matcher ikke resultatet: ifølge resultatet vandt %(winner)s (%(t1)s–%(t2)s sæt), men du valgte %(selected)s som vinder."

msgid "Invalid data."
msgstr "Ugyldige data."

msgid "The file could not be read as JSON."
msgstr "Filen kunne ikke læses som JSON."

msgid "Unknown backup format (version missing or incorrect)."
msgstr "Ukendt backup-format (version mangler eller er forkert)."

msgid "No file selected."
msgstr "Ingen fil valgt."

# ── Views – flash messages ──────────────────────────────────────────────

msgid "Rest period for %(name)s has been cleared."
msgstr "Hvileperiode for %(name)s er slettet."

msgid "Result saved."
msgstr "Resultat gemt."

msgid "Walk-over recorded – %(winner)s wins."
msgstr "Walk-over registreret – %(winner)s vinder."

msgid "Match #%(n)s is now in progress."
msgstr "Kamp #%(n)s er nu i gang."

msgid "The schedule is locked and cannot be changed."
msgstr "Spilleplanen er låst og kan ikke ændres."

msgid "The schedule is now locked."
msgstr "Spilleplanen er nu låst."

msgid "The schedule is now unlocked."
msgstr "Spilleplanen er nu låst op."

msgid "Schedule generated with %(n)s matches."
msgstr "Kampprogram genereret med %(n)s kampe."

msgid "Schedule generated with %(n)s matches (+ %(p)s bracket final matches reserved)."
msgstr "Kampprogram genereret med %(n)s kampe (+ %(p)s slutspilsfinaler reserveret)."

msgid "Schedule generated: %(group)s group matches in %(gc)s groups + %(playoff)s playoff matches (scheduled after group stage)."
msgstr "Kampprogram genereret: %(group)s gruppekampe i %(gc)s grupper + %(playoff)s slutspilskampe (planlagt efter gruppespil)."

msgid "Time schedule generated for %(n)s matches."
msgstr "Spilleplan genereret for %(n)s kampe."

msgid "No matches generated."
msgstr "Ingen kampe genereret."

msgid "No matches to schedule. Generate match programmes for divisions first."
msgstr "Ingen kampe at planlægge. Generer kamprogrammer for rækker først."

msgid "Set a start time on the tournament before generating the time schedule."
msgstr "Angiv et starttidspunkt på turneringen før du genererer spilleplanen."

msgid "All matches deleted and match number counter reset."
msgstr "Alle kampe slettet og kampnummertæller nulstillet."

msgid "Match numbers recalculated – %(n)s matches numbered from 1."
msgstr "Kampnumre genberegnet – %(n)s kampe nummereret fra 1."

msgid "Match numbers sorted by schedule – %(n)s matches numbered from 1."
msgstr "Kampnumre sorteret efter spilleplan – %(n)s kampe nummereret fra 1."

msgid "Match numbers sorted by schedule – %(n)s matches numbered from 1 (%(u)s without time placed last)."
msgstr "Kampnumre sorteret efter spilleplan – %(n)s kampe nummereret fra 1 (%(u)s uden tid placeret sidst)."

msgid "Bracket labels rebuilt (%(n)s matches updated)."
msgstr "Slutspilsetiketter genopbygget (%(n)s kampe opdateret)."

msgid "Bracket match updated: %(t1)s vs %(t2)s."
msgstr "Slutspilskamp opdateret: %(t1)s vs %(t2)s."

msgid "Cannot reassign groups – results have already been recorded."
msgstr "Kan ikke omfordele grupper – resultater er allerede registreret."

msgid "Group reassignment is only possible for divisions with group stage and playoff bracket."
msgstr "Omfordeling af grupper er kun mulig for rækker med gruppespil og slutspilsbracket."

msgid "Groups do not contain exactly the right teams."
msgstr "Grupper indeholder ikke præcis de rigtige hold."

msgid "%(n)s default categories have been added."
msgstr "%(n)s standardkategorier er tilføjet."

msgid "All default categories already exist."
msgstr "Alle standardkategorier eksisterer allerede."

msgid "Cannot start match: "
msgstr "Kan ikke starte kamp: "

msgid "You must type DELETE TOURNAMENT to confirm."
msgstr "Du skal skrive SLET TURNERING for at bekræfte."

msgid "You must type RESET SCHEDULE to confirm."
msgstr "Du skal skrive NULSTIL SPILLEPLAN for at bekræfte."

