# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
#
# Generate a secret key with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"

SECRET_KEY=change-to-a-long-random-string-at-least-50-characters
POSTGRES_DB=badminton
POSTGRES_USER=badminton
POSTGRES_PASSWORD=change-this-to-something-secure
ALLOWED_HOSTS=localhost,your-domain.example

# Fully-qualified origins (https://…) allowed to submit CSRF-protected POSTs.
# REQUIRED when serving over HTTPS behind a reverse proxy.
# Comma-separated. Example: https://turnering.example.dk,https://www.example.dk
CSRF_TRUSTED_ORIGINS=

# HTTPS hardening — OPT-IN. Leave as False until nginx has a working TLS cert.
# Turning this on without HTTPS will 301-loop and break login (secure cookies
# are dropped over plain http).
ENABLE_HTTPS_HARDENING=False
# These only take effect when ENABLE_HTTPS_HARDENING=True.
# Set SECURE_SSL_REDIRECT=False if TLS is terminated upstream and you
# don't want Django to issue 301-to-https on every request.
SECURE_SSL_REDIRECT=True
# Seconds browsers should remember to only use HTTPS for this host.
# Set to 0 temporarily while obtaining/rotating certificates.
SECURE_HSTS_SECONDS=31536000

# Content-Security-Policy. Start in report-only mode so violations are
# logged to the browser console without blocking. Flip to False to enforce.
BTP_CSP_REPORT_ONLY=True

# Move Django admin off the well-known /admin/ path to cut brute-force noise.
# Must end with '/'. Example: ADMIN_URL=staff-7x2/
ADMIN_URL=admin/

# Backup encryption (optional). When set, daily archives are encrypted with
# age before being written to /backups and before any S3 upload.
# Provide one or more age recipient public keys (space-separated), e.g.:
#   BACKUP_AGE_RECIPIENTS=age1xyz... age1abc...
# To restore, decrypt with: `age -d -i identity.txt FILE.age > FILE`
BACKUP_AGE_RECIPIENTS=

# Django admin superuser (created automatically on first startup).
# After the first successful startup it is RECOMMENDED to remove the
# password line from .env so a leaked .env doesn't reveal admin access.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-this-to-something-secure


## Backup settings
BACKUP_DIR=./backups
BACKUP_HOUR=2
BACKUP_RETENTION_DAILY=14
BACKUP_RETENTION_MONTHLY=12
BACKUP_ON_START=0
TZ=Europe/Copenhagen


## Offsite backup settings (optional)
S3_BUCKET=
S3_PREFIX=
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=